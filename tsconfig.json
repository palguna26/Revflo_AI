{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "lib": [
            "ES2020"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "moduleResolution": "node",
        "outDir": ".vercel/output",
        "baseUrl": ".",
        "paths": {
            "@/lib/*": [
                "lib/*"
            ],
            "@/types/*": [
                "types/*"
            ]
        }
    },
    "include": [
        "api/**/*",
        "lib/**/*",
        "types/**/*"
    ],
    "exclude": [
        "node_modules",
        "frontend",
        "backend"
    ]
}